{
  "name": "aiaudiojs",
  "version": "0.5.3",
  "description": "Thin Web Audio shell over Howler.js — dispose() idempotency, AbortSignal cancellation, first-class equal-power crossfade(), and ai*js conventions. Howler stays as a peerDependency.",
  "keywords": [
    "audio",
    "web-audio",
    "howler",
    "game-audio",
    "crossfade",
    "ios-unlock",
    "ai-readable",
    "typescript",
    "esm"
  ],
  "author": "yshengliao",
  "license": "MIT",
  "homepage": "https://github.com/yshengliao/aiaudiojs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yshengliao/aiaudiojs.git"
  },
  "bugs": {
    "url": "https://github.com/yshengliao/aiaudiojs/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_ZHTW.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "verify:exports": "node scripts/verify-exports.mjs",
    "check:size": "node scripts/check-size.mjs",
    "build:llms": "node scripts/build-llms-full.mjs",
    "verify:llms": "node scripts/build-llms-full.mjs --check",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm coverage && pnpm build && pnpm verify:exports && pnpm verify:llms && pnpm check:size"
  },
  "peerDependencies": {
    "howler": "^2.2.4"
  },
  "peerDependenciesMeta": {
    "howler": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/howler": "^2.2.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.9.0",
    "howler": "^2.2.4",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "publishConfig": {
    "access": "public"
  }
}
